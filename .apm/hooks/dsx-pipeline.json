{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": { "tool_name": "Write|Edit" },
        "hooks": [
          {
            "type": "command",
            "command": "pnpm exec biome format --write \"$CLAUDE_FILE_PATHS\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "node scripts/pipeline.mjs" }]
      }
    ]
  }
}
