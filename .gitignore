# Dependencies
node_modules/
.pnp/
.pnp.*

# Build outputs
.next/
out/
dist/
.turbo/
*.tsbuildinfo

# Style Dictionary outputs (regenerated by `pnpm tokens`).
# Ignore contents of build/ but keep the directory itself via build/.gitkeep.
build/*
!build/.gitkeep

# Test artifacts
playwright-report/
test-results/
**/*-snapshots/__diff_output__/
coverage/

# APM-generated client trees. Authored once under .apm/, deployed by
# `apm install`. Anything below these roots is a regenerable output;
# the canonical source lives in .apm/.
.claude/
.cursor/
.codex/
.opencode/
.agents/
.github/instructions/
.github/prompts/
.github/agents/
.github/skills/
.github/hooks/
.github/copilot-instructions.md

# APM dependency cache
apm_modules/

# Editor / OS
.DS_Store
*.log
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# Env
.env
.env.local
.env.*.local
