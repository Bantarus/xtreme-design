# Dependencies
node_modules/
.pnp/
.pnp.*

# Build outputs
.next/
out/
dist/
.turbo/
*.tsbuildinfo

# Style Dictionary outputs (regenerated by `pnpm tokens`).
# Ignore contents of build/ but keep the directory itself via build/.gitkeep.
build/*
!build/.gitkeep

# Test artifacts
playwright-report/
test-results/
**/*-snapshots/__diff_output__/
coverage/

# Claude Code worktrees (subagent isolation)
.claude/worktrees/

# Editor / OS
.DS_Store
*.log
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# Env
.env
.env.local
.env.*.local
