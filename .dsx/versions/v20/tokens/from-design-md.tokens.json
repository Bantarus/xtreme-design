{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Helios is a warm, content-forward design system. Quiet surfaces, dense type, one decisive amber accent. Place-holder brand for the dsx scaffold — rename to your real brand before shipping.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.478, 0.243, 0.047],
        "hex": "#7a3e0c"
      }
    },
    "primary-hover": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.369, 0.184, 0.031],
        "hex": "#5e2f08"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [1, 1, 1],
        "hex": "#ffffff"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.98, 0.973, 0.953],
        "hex": "#faf8f3"
      }
    },
    "surface-muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.937, 0.922, 0.886],
        "hex": "#efebe2"
      }
    },
    "text": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.086, 0.075, 0.067],
        "hex": "#161311"
      }
    },
    "text-muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.341, 0.322, 0.29],
        "hex": "#57524a"
      }
    },
    "border": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.847, 0.824, 0.773],
        "hex": "#d8d2c5"
      }
    },
    "border-strong": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.69, 0.659, 0.604],
        "hex": "#b0a89a"
      }
    },
    "success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.184, 0.427, 0.227],
        "hex": "#2f6d3a"
      }
    },
    "danger": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.698, 0.227, 0.165],
        "hex": "#b23a2a"
      }
    },
    "warning": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.549, 0.353, 0],
        "hex": "#8c5a00"
      }
    },
    "info": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.118, 0.353, 0.549],
        "hex": "#1e5a8c"
      }
    },
    "focus-ring": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.847, 0.608, 0.369],
        "hex": "#d89b5e"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "2xl": {
      "$value": {
        "value": 48,
        "unit": "px"
      }
    },
    "3xl": {
      "$value": {
        "value": 64,
        "unit": "px"
      }
    },
    "gutter": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "margin": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "full": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 48,
          "unit": "px"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": -0.02,
          "unit": "em"
        }
      }
    },
    "headline-lg": {
