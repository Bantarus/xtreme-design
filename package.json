{
  "name": "dsx",
  "version": "0.0.0",
  "private": true,
  "description": "Agent-native design system monorepo (web-first, mobile placeholders).",
  "author": "Bantarus",
  "license": "MIT",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "format": "biome format --write .",
    "tokens": "node style-dictionary.config.mjs",
    "pipeline": "node scripts/pipeline.mjs",
    "design:lint": "design-md lint DESIGN.md",
    "design:sync": "node scripts/design-md-sync.mjs",
    "gallery:dev": "pnpm --filter gallery dev",
    "gallery:build": "pnpm --filter gallery build",
    "gallery:start": "pnpm --filter gallery start",
    "registry:build": "shadcn build registry/registry.json -o apps/gallery/public/r/",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@google/design.md": "latest",
    "@playwright/test": "^1.49.0",
    "style-dictionary": "^4.4.0",
    "turbo": "^2.5.0",
    "typescript": "^5.6.0",
    "yaml": "^2.9.0"
  }
}
